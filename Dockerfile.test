FROM gradle:8.12.1-jdk21

USER root
# No Ubuntu 24.04 (base desta imagem), o pacote "chromium" é um shim do Snap que
# não funciona dentro de Docker. Instala o Google Chrome Stable a partir do
# repositório oficial do Google, que distribui um .deb nativo.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates wget gnupg \
    && wget -qO- https://dl.google.com/linux/linux_signing_key.pub \
       | gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] \
       http://dl.google.com/linux/chrome/deb/ stable main" \
       > /etc/apt/sources.list.d/google-chrome.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends google-chrome-stable \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /home/gradle/project
# WORKDIR cria o diretório como root; corrige ownership para o usuário gradle
# poder criar o cache local (.gradle/) em tempo de execução
RUN chown gradle:gradle /home/gradle/project

ENV CHROME_BIN=/usr/bin/google-chrome-stable
# CHROMEDRIVER_PATH não definido: SeleniumDriverFactory usa WebDriverManager
# para baixar a versão do ChromeDriver compatível com o Chrome instalado.
ENV GRADLE_USER_HOME=/home/gradle/.gradle

COPY --chown=gradle:gradle build.gradle settings.gradle ./
COPY --chown=gradle:gradle src ./src
COPY --chown=gradle:gradle docker/scripts ./docker/scripts

USER gradle

ENTRYPOINT ["bash", "./docker/scripts/executar-gradle.sh"]
