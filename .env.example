# =============================================
# PDV - Variaveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no repositorio.
#
# Para subir o banco local: docker-compose up -d
# Para rodar com PostgreSQL: gradle bootRun --args='--spring.profiles.active=postgres'
# =============================================

# Conexao com o banco PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/pdvdb
DB_USERNAME=pdvuser
DB_PASSWORD=pdvpass
